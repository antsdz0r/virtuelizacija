<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>

  <appSettings>
    <!-- Root directory that contains subject_X_results.csv files (Task 5) -->
    <add key="EegDataPath" value="EEG" />

    <!-- Directory where downloaded files are saved (Task 8) -->
    <add key="ClientOutputPath" value="Downloaded" />
  </appSettings>

  <system.serviceModel>
    <client>
      <endpoint name="EegService"
                address="net.tcp://localhost:5000/EegService"
                binding="netTcpBinding"
                bindingConfiguration="EegNetTcpBinding"
                contract="Common.IEegService" />
    </client>

    <bindings>
      <netTcpBinding>
        <binding name="EegNetTcpBinding"
                 transferMode="Buffered"
                 maxReceivedMessageSize="10485760"
                 receiveTimeout="00:10:00"
                 sendTimeout="00:10:00"
                 openTimeout="00:01:00"
                 closeTimeout="00:01:00" />
      </netTcpBinding>
    </bindings>
  </system.serviceModel>
</configuration>
