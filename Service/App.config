<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>

  <!-- ── Application settings (thresholds, paths) ───────────────────────── -->
  <appSettings>
    <!-- Directory where received EEG files are stored. Created automatically. -->
    <add key="DataPath" value="Data" />

    <!-- Analytics thresholds (Task 9 & 10) -->
    <add key="StressSpikeThreshold"   value="10.0" />
    <add key="RelaxationDropThreshold" value="10.0" />
    <add key="BatteryLowThreshold"    value="20" />
    <add key="ContactQualityMin"      value="3" />
    <add key="TimestampSkewMaxMs"     value="2000" />
    <add key="ChannelOutOfBandPct"    value="25" />
  </appSettings>

  <!-- ── WCF Service host ─────────────────────────────────────────────────── -->
  <system.serviceModel>
    <services>
      <service name="Service.EegService">
        <host>
          <baseAddresses>
            <add baseAddress="net.tcp://localhost:5000" />
          </baseAddresses>
        </host>
        <endpoint
          address="EegService"
          binding="netTcpBinding"
          bindingConfiguration="EegNetTcpBinding"
          contract="Common.IEegService" />
      </service>
    </services>

    <bindings>
      <netTcpBinding>
        <binding name="EegNetTcpBinding"
                 transferMode="Buffered"
                 maxReceivedMessageSize="10485760"
                 receiveTimeout="00:10:00"
                 sendTimeout="00:10:00"
                 openTimeout="00:01:00"
                 closeTimeout="00:01:00" />
      </netTcpBinding>
    </bindings>
  </system.serviceModel>
</configuration>
